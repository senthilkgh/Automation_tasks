      "id": "node-consensus",
      "name": "\ud83e\uddee Consensus Merger",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ],
      "parameters": {
        "jsCode": "// Safe JSON parser for AI responses\nfunction parseAI(raw) {\n  if (!raw) return [];\n  try {\n    const s = (typeof raw==='string'?raw:JSON.stringify(raw))\n      .replace(/```json/gi,'').replace(/```/g,'').trim();\n    const p = JSON.parse(s);\n    return Array.isArray(p)?p:[];\n  } catch { return []; }\n}\n\nconst data = items[0].json;\nconst picks = data.topPicks||[];\n\n// Each AI node response path\nconst claudeRecs =     parseAI(data.claudeResp?.content?.[0]?.text);\nconst geminiRecs =     parseAI(data.geminiResp?.candidates?.[0]?.content?.parts?.[0]?.text);\nconst grokRecs =       parseAI(data.grokResp?.choices?.[0]?.message?.content);\nconst perplexRecs =    parseAI(data.perplexResp?.choices?.[0]?.message?.content);\n\nconst allRecs = [...claudeRecs,...geminiRecs,...grokRecs,...perplexRecs];\nconst advisorCount = [claudeRecs,geminiRecs,grokRecs,perplexRecs].filter(r=>r.length>0).length;\n\n// Build AI map per symbol\nconst aiMap = {};\nfor (const r of allRecs) {\n  if (!r.symbol) continue;\n  if (!aiMap[r.symbol]) aiMap[r.symbol]={buyScore:0,count:0,reasons:[]};\n  aiMap[r.symbol].buyScore += r.rec==='BUY'?(r.confidence||50):0;\n  aiMap[r.symbol].count++;\n  if (r.reason) aiMap[r.symbol].reasons.push(r.reason);\n}\n\nconst profitPct = data.PROFIT_TARGET_PCT||20;\nconst slPct = data.STOPLOSS_PCT||2;\n\nconst finalPicks = picks.map(p => {\n  const ai = aiMap[p.symbol]||{buyScore:0,count:0,reasons:['Tech only']};\n  const aiScore = ai.count>0?ai.buyScore/ai.count:50;\n  const geoScore = data.geoScore||55;\n  const tw = advisorCount>0?0.50:0.70;\n  const aw = advisorCount>0?0.30:0;\n  const gw = 1-tw-aw;\n  const composite = p.techScore*tw + aiScore*aw + geoScore*gw;\n  return {\n    ...p, aiScore:+aiScore.toFixed(1), geoScore,\n    composite:+composite.toFixed(1),\n    recommendation: composite>=55?'BUY':'SKIP',\n    aiReasons: ai.reasons.slice(0,2),\n    advisorsUsed: advisorCount\n  };\n}).filter(p=>p.recommendation==='BUY')\n  .sort((a,b)=>b.composite-a.composite);\n\nreturn [{ json: { ...data, finalPicks, hasBuySignals:finalPicks.length>0, advisorsUsed:advisorCount } }];"
      }
    },
