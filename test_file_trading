    {
      "id": "node-build-msg",
      "name": "📝 Build Alert Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2120, 180],
      "parameters": {
        "jsCode": "const data = items[0].json;\nconst picks = data.finalPicks||[];\nconst risk = data.riskFlags||{};\nconst isMock = picks.some(p=>p._mock);\nconst lines = picks.map((p,i)=>\n  `${i+1}. *${p.symbol}* — Score: ${p.composite}/100\\n` +\n  `   LTP: ₹${p.ltp} | Qty: ${p.qty} | Cost: ₹${p.costToTrade}\\n` +\n  `   Target: ₹${p.target} (+${data.PROFIT_TARGET_PCT}%) | SL: ₹${p.stopLoss} (-${data.STOPLOSS_PCT}%)\\n` +\n  `   Tech:${p.techScore} AI:${p.aiScore} Geo:${p.geoScore}\\n` +\n  (p.aiReasons?.[0]?`   ${p.aiReasons[0]}\\n`:'')\n).join('\\n');\nconst now = new Date().toLocaleString('en-IN',{timeZone:'Asia/Kolkata'});\nconst msg =\n  `📊 *AUTO-TRADER ALERT*\\n${now}\\n` +\n  `━━━━━━━━━━━━━━━━\\n` +\n  (isMock?`⚠️ DRY-RUN MODE (no Zerodha key)\\n`:'')+\n  `AI Advisors: ${data.advisorsUsed||0}/4 active\\n\\n` +\n  lines +\n  `\\n━━━━━━━━━━━━━━━━\\n` +\n  `Budget: ₹${risk.totalCost} / ₹${data.DAILY_BUDGET} (${risk.budgetUsedPct}%)\\n` +\n  `R:R = ${risk.riskReward}:1\\n\\n` +\n  `Reply *CONFIRM* to execute | *SKIP* to cancel`;\nreturn [{ json: { ...data, alertMessage:msg, alertTime:now } }];"
