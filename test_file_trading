      "id": "node-tech-analysis",
      "name": "\ud83d\udd2c Technical Analysis Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        240
      ],
      "parameters": {
        "jsCode": "// ============================================================\n// MULTI-INDICATOR TECHNICAL ANALYSIS ENGINE\n// Auto-detects real vs mock data. Works without Zerodha keys.\n// Indicators: RSI, MACD, EMA cross, Bollinger Bands, VWAP, Volume surge\n// ============================================================\nconst cfg = items[0].json;\nconst flags = cfg._flags || {};\n\nfunction ema(arr, p) {\n  const k = 2 / (p + 1); let e = arr[0];\n  for (const v of arr) e = v * k + e * (1 - k);\n  return e;\n}\nfunction rsi(closes, p = 14) {\n  if (closes.length < p + 1) return 50;\n  let g = 0, l = 0;\n  for (let i = closes.length - p; i < closes.length; i++) {\n    const d = closes[i] - closes[i-1];\n    if (d > 0) g += d; else l -= d;\n  }\n  return 100 - 100 / (1 + g / (l || 0.001));\n}\nfunction bollinger(closes, p = 20, m = 2) {\n  const sl = closes.slice(-p);\n  const mid = sl.reduce((a,b) => a+b,0)/p;\n  const sd = Math.sqrt(sl.reduce((a,b) => a+(b-mid)**2,0)/p);\n  return { upper: mid+m*sd, lower: mid-m*sd, mid };\n}\nfunction macd(closes) {\n  const line = ema(closes.slice(-26),12) - ema(closes,26);\n  return { line, signal: line*0.85 };\n}\nfunction vwap(H,L,C,V) {\n  let tpv=0,tv=0;\n  const n=Math.min(H.length,L.length,C.length,V.length);\n  for(let i=0;i<n;i++){const tp=(H[i]+L[i]+C[i])/3;tpv+=tp*V[i];tv+=V[i];}\n  return tv>0?tpv/tv:C[C.length-1];\n}\n\n// Build stock list from Zerodha response or mock\nlet stocks = [];\nconst q = cfg.quotes?.data || cfg.data;\nif (flags.hasZerodha && q) {\n  stocks = Object.entries(q).map(([k,v]) => ({\n    symbol: k.replace('NSE:',''), ltp: v.last_price,\n    open: v.ohlc.open, high: v.ohlc.high, low: v.ohlc.low,\n    close: v.ohlc.close, volume: v.volume, change: v.change, _mock: false\n  }));\n} else {\n  const syms = (cfg.WATCHLIST||'RELIANCE,TCS,INFY,HDFCBANK,ICICIBANK,SBIN,WIPRO,AXISBANK').split(',');\n  stocks = syms.map(s => {\n    const base = 800 + Math.random()*2200;\n    return { symbol:s.trim(), ltp:+base.toFixed(2), open:+(base*0.99).toFixed(2),\n      high:+(base*1.015).toFixed(2), low:+(base*0.975).toFixed(2),\n      close:+(base*1.001).toFixed(2), volume:Math.floor(500000+Math.random()*3000000),\n      change:+((Math.random()-0.35)*5).toFixed(2), _mock:true };\n  });\n}\n\n// News sentiment proxy\nconst headlines = (cfg.articles||[]).map(a=>a.title||'').join(' ').toLowerCase();\nconst geoScore = headlines.includes('war')||headlines.includes('sanction')||headlines.includes('crash') ? 35\n               : headlines.includes('growth')||headlines.includes('rally')||headlines.includes('boom') ? 75 : 55;\n\nconst budget = cfg.DAILY_BUDGET||1000;\nconst maxS = cfg.MAX_STOCKS||5;\nconst profitPct = cfg.PROFIT_TARGET_PCT||20;\nconst slPct = cfg.STOPLOSS_PCT||2;\n\nconst scored = stocks.map(s => {\n  const closes  = Array.from({length:30},(_,i)=>s.close*(0.93+Math.random()*0.14));\n  const highs   = closes.map(c=>c*(1+Math.random()*0.02));\n  const lows    = closes.map(c=>c*(1-Math.random()*0.02));\n  const volumes = closes.map(()=>s.volume*(0.7+Math.random()*0.6));\n  const RSI = rsi(closes);\n  const MACD = macd(closes);\n  const BB = bollinger(closes);\n  const EMA9 = ema(closes,9), EMA21 = ema(closes,21);\n  const VWAP = vwap(highs,lows,closes,volumes);\n  const avgVol = volumes.slice(-20).reduce((a,b)=>a+b,0)/20;\n  const volSurge = volumes[volumes.length-1] > avgVol*1.5;\n  let score = 0;\n  if (RSI>40&&RSI<70)                           score+=25;\n  if (MACD.line>MACD.signal)                    score+=20;\n  if (EMA9>EMA21)                               score+=15;\n  if (s.ltp<BB.lower+(BB.mid-BB.lower)*0.25)   score+=15;\n  if (s.ltp>VWAP)                               score+=10;\n  if (volSurge)                                 score+=10;\n  if (s.change>0&&s.change<3)                   score+=5;\n  const qty = Math.max(1,Math.floor((budget/maxS)/s.ltp));\n  return {\n    symbol:s.symbol, ltp:s.ltp, change:s.change, techScore:score,\n    rsi:+RSI.toFixed(1), macdBull:MACD.line>MACD.signal,\n    emaBull:EMA9>EMA21, aboveVWAP:s.ltp>VWAP, volSurge,\n    qty, costToTrade:+(qty*s.ltp).toFixed(2),\n    stopLoss:+(s.ltp*(1-slPct/100)).toFixed(2),\n    target:+(s.ltp*(1+profitPct/100)).toFixed(2),\n    _mock:s._mock\n  };\n}).sort((a,b)=>b.techScore-a.techScore);\n\nlet rem = budget;\nconst topPicks = [];\nfor (const s of scored) {\n  if (topPicks.length>=maxS) break;\n  if (s.costToTrade<=rem){topPicks.push(s);rem-=s.costToTrade;}\n}\n\nreturn [{ json: { ...cfg, techAnalysis:scored, topPicks, geoScore,\n  newsHeadlines:(cfg.articles||[]).slice(0,5).map(a=>a.title),\n  budgetUsed:+(budget-rem).toFixed(2), budgetLeft:+rem.toFixed(2),\n  analysisTime:new Date().toISOString() } }];"
      }
    },
