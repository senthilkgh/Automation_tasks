        "jsCode": "const pos = items[0].json?.data?.net||[];\nconst now = new Date();\nconst ist = d => new Intl.DateTimeFormat('en-IN',{...d,timeZone:'Asia/Kolkata'}).format(now);\nconst h = parseInt(ist({hour:'numeric',hour12:false}));\nconst m = parseInt(ist({minute:'numeric'}));\nconst isEOD = h===15&&m>=10;\nconst alerts=[], toExit=[];\nfor (const p of pos) {\n  if (!p.quantity) continue;\n  const pnlPct = p.average_price>0?(p.pnl/(p.average_price*Math.abs(p.quantity))*100):0;\n  if (isEOD) { toExit.push({symbol:p.tradingsymbol,qty:p.quantity,reason:'EOD'}); alerts.push(`⏰ EOD: ${p.tradingsymbol} P&L ₹${(p.pnl||0).toFixed(0)}`); }\n}\nreturn [{ json:{positions:pos,toExit,alerts,isEOD,ts:now.toISOString()} }];"
